# ============================================================
# mosupisi-weather-service — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values you have.
# Lines starting with # are comments.
# ============================================================

# -- Service --
PORT=8002
ENVIRONMENT=development          # development | production

# -- Database --
# SQLite path (relative to service root). To migrate to PostgreSQL,
# replace this with a full asyncpg URL and update db/database.py.
DATABASE_PATH=data/weather.db

# -- NASA POWER API --
# No API key required — NASA POWER is publicly accessible.
# Override the base URL only if you need to point at a mirror or mock server.
NASA_POWER_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# -- OpenWeatherMap --
# Sign up at https://openweathermap.org/api to get a key.
# One Call API 3.0 requires a paid subscription (free tier available).
# Leave blank to run in mock mode (mock data will be returned).
OPENWEATHERMAP_API_KEY=

# -- Lesotho Meteorological Services (LMS) --
# Currently in STUB mode — returns None so other sources are used.
# When you have LMS API access, fill in these values and set LMS_STUB_MODE=false.
# Contact: https://www.met.gov.ls
LMS_API_URL=
LMS_API_KEY=
LMS_STUB_MODE=true

# -- Twilio SMS Alerts --
# Leave TWILIO_ENABLED=false to run in stub mode (logs SMS to console).
# Activate when ready:
#   1. pip install twilio
#   2. Get credentials from https://console.twilio.com
#   3. Set TWILIO_ENABLED=true
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=              # Your Twilio number e.g. +26622XXXXXX

# -- CORS --
# Add frontend origins separated by commas (no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
